{
  "name": "localchat-app",
  "version": "1.0.0",
  "description": "LAN-only ephemeral chat and file sharing — no internet, no persistence by default",
  "bin": {
    "localchat": "./bin/localchat.js"
  },
  "files": [
    "bin/",
    "lib/",
    "public/",
    "client/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "cd client && npm install && npm run build",
    "start": "node lib/cli.js start"
  },
  "keywords": [
    "chat",
    "lan",
    "local",
    "file-sharing",
    "team",
    "offline",
    "intranet"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Iam-Divyesh/localchat"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bonjour-service": "^1.2.1",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5"
  }
}
