# Server port
# Use 80 for clean URLs (http://localchat.local with no port)
# On Windows port 80 requires admin — run: localchat setup-port80
# For dev without admin, use 3000 and access via http://localchat.local:3000
PORT=80

# Max file size in MB (default: 200)
MAX_FILE_SIZE_MB=200

# File expiry in minutes (default: 5)
FILE_EXPIRY_MINUTES=5

# mDNS name — accessible as http://<MDNS_NAME>.local
# Change with: localchat domain <name>
MDNS_NAME=localchat

# UDP broadcast port for LAN discovery (default: 41234)
UDP_BROADCAST_PORT=41234

# Enable SQLite persistence (messages survive server restarts)
# Enable with: localchat persist on  OR  --persist flag
PERSIST=false

# Directory for SQLite database (default: ~/.localchat)
# DATA_DIR=
