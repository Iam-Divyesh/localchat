{
  "name": "localchat",
  "version": "1.0.0",
  "description": "LAN-only ephemeral chat and file sharing — no internet, no persistence by default",
  "main": "dist/index.js",
  "bin": {
    "localchat": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "client-dist/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:client": "cd ../client && npm install && npm run build",
    "build:all": "npm run build:client && cp -r ../client/dist ./client-dist && npm run build",
    "build:all:win": "npm run build:client && xcopy /E /I /Y ..\\client\\dist client-dist",
    "start": "node dist/cli.js start"
  },
  "keywords": [
    "chat",
    "lan",
    "local",
    "file-sharing",
    "team",
    "offline",
    "intranet"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Iam-Divyesh/localchat"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bonjour-service": "^1.2.1",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
